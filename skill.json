{
  "name": "markhub",
  "displayName": "MarkHub v6.5 - Local AI + ComfyUI + Zopia Video System",
  "version": "6.5.0",
  "description": "Complete AI creation system: Local SD (100% offline), ComfyUI remote management (ComfyNexus), Zopia AI video production. Environment snapshots, plugin management, Agent chat workflow.",
  "author": "1 号小虫子",
  "license": "MIT",
  "keywords": ["image-generation", "video", "comfyui", "zopia", "local-ai", "stable-diffusion", "comfynexus", "environment-management"],
  "main": "markhub_v6_1.py",
  "requires": {
    "bins": ["python3", "ffmpeg", "git"],
    "python_packages": ["stable-diffusion-cpp-python", "pillow", "numpy", "requests"]
  },
  "features": [
    "✅ Local AI Generation - 100% offline with stable-diffusion-cpp-python",
    "✅ ComfyUI Remote - Multi-platform support (RunPod/Vast.ai/Local)",
    "✅ Zopia AI Video - Agent chat workflow (screenplay→character→storyboard→video)",
    "✅ ComfyNexus Integration - Environment & plugin management",
    "✅ Environment Snapshots - Backup and restore configurations",
    "✅ Plugin Conflict Detection - Automatic scanning",
    "✅ GitHub Plugin Search - Built-in marketplace",
    "✅ Hardware Monitoring - Real-time GPU/CPU/Memory stats",
    "✅ 4 Zopia Presets - Anime/3D/Pixar/Vertical video",
    "✅ Performance Optimized - Local ops < 3ms response time"
  ],
  "usage": {
    "install": "cd ~/.jvs/.openclaw/workspace/skills/markhub && bash install.sh",
    "local_image": "python3 markhub_v6_1.py -p \"A beautiful woman\"",
    "comfyui_video": "python3 markhub_core.py -p \"A woman dancing\" --video --duration 10",
    "zopia_project": "python3 -m modules.zopia -t zopia-xxxx -a create -n \"My Video\"",
    "env_info": "python3 -m modules.comfynexus.environment_manager -a info",
    "plugin_list": "python3 -m modules.comfynexus.plugin_manager -a list -c /path/to/ComfyUI"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yun520-1/markhub-skill"
  },
